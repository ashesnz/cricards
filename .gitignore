# .gitignore for Godot project (C# / Mono)
# Generated to ignore editor/engine generated files, build outputs and IDE/user files.

# --------------------
# Godot-specific
# --------------------
# Imported resource files (auto-generated by Godot)
/.import/
*.import

# Godot editor and export cache
/.godot/
/.export/

# Export presets often contain local paths/passwords - ignore if you don't want to track them
/export_presets.cfg

# Explicitly ignore GodotReferences and everything inside it (as requested)
/GodotReferences/

# --------------------
# Mono / C# / build artifacts
# --------------------
# Mono intermediate and build directories
/.mono/
bin/
obj/
Debug/
Release/

# Common C# build outputs
*.dll
*.exe
*.pdb
*.mdb
*.apk
*.a
*.so
*.dylib

# Visual Studio / Rider / IDE files
/.vs/
/.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# VS Code
/.vscode/

# Rider caches
*.iml

# --------------------
# OS files & editor swap files
# --------------------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~

# Logs, caches
.cache/
*.log

# Temporary files
*.tmp

# End of .gitignore




